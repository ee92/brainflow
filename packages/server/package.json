{
  "name": "@brainflow/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/",
    "start": "node dist/index.js",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.0.0",
    "pg": "^8.13.0",
    "pino": "^9.0.0",
    "pino-http": "^9.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "22.19.13",
    "@types/pg": "8.16.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
